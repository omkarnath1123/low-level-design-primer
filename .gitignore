# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDE — IntelliJ IDEA ──────────────────────────────────────────────────────
# .idea/ and *.iml are NOT ignored — they are committed so IntelliJ opens
# this repo fully indexed with all modules. Only user-local files are excluded.
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/
*.ipr
*.iws

# ─── IDE — VS Code ────────────────────────────────────────────────────────────
.vscode/

# ─── IDE — Eclipse / STS ──────────────────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# ─── IDE — NetBeans ───────────────────────────────────────────────────────────
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ─── Build outputs (scoped to solutions — source is tracked, artifacts are not)
solutions/**/target/
solutions/**/build/
solutions/**/.gradle/
solutions/**/out/
solutions/**/gradle-app.setting
solutions/**/.gradletasknamecache
solutions/**/HELP.md

# ─── Java artifacts ───────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.nar
*.ear
# Keep Gradle wrapper jar — it is a required binary committed to the repo
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar
!gradle-wrapper.jar

# BlueJ / legacy tools
*.ctxt
.mtj.tmp/
hs_err_pid*

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ─── Go ───────────────────────────────────────────────────────────────────────
*.exe

# ─── Archives (never commit generated zips/tarballs) ──────────────────────────
*.zip
*.tar.gz
*.rar
